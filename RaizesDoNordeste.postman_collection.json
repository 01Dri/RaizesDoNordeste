				{
					"name": "Login do Desenvolvedor (Fácil e Automático)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.isSuccess && jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.data.token);",
									"    console.log(\"Token salvo na variável: \" + jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/desenvolvedor",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"desenvolvedor"
							]
						},
						"description": "Gera um token JWT com perfil de Administrador e salva automaticamente na variável de coleção 'token'."
					},
					"response": []
				},
