		{
			"name": "Pedidos",
			"item": [
				{
					"name": "Criar Pedido com Sucesso (Canal Válido)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set(\"orderId\", jsonData.id);",
									"    console.log(\"ID do pedido criado salvo: \" + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"canalPedido\": \"TOTEM\",\n  \"items\": [\n    {\n      \"publicMenuItemId\": \"9a88024d-2618-4e25-87f5-35217f7a7c9b\",\n      \"quantity\": 1\n    }\n  ]\n}",
							"options": {
